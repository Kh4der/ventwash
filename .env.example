# ── PostHog (analytics) ──────────────────────────────────────────────
# Project API key — PostHog → Settings → Project → Project API Key (starts with phc_)
NEXT_PUBLIC_POSTHOG_KEY=

# Only set these if your PostHog project is NOT in the US cloud (e.g. EU):
# NEXT_PUBLIC_POSTHOG_INGEST_HOST=https://eu.i.posthog.com
# NEXT_PUBLIC_POSTHOG_ASSETS_HOST=https://eu-assets.i.posthog.com
# NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# ── PostHog private API (powers the /admin dashboard) ────────────────
# Personal API key — PostHog → Settings → User → Personal API Keys (starts with phx_)
# Needs "Query Read" scope.
POSTHOG_PERSONAL_API_KEY=
# Numeric project id — visible in the PostHog URL: app.posthog.com/project/<id>
POSTHOG_PROJECT_ID=
# Only set if not US cloud:
# POSTHOG_API_HOST=https://eu.posthog.com

# ── Admin panel ──────────────────────────────────────────────────────
# Password for /admin. CHANGE THIS before deploying.
ADMIN_PASSWORD=
# Random string used to sign the admin session cookie.
SESSION_SECRET=

# ═══════════════════════════════════════════════════════════════════════
# Automation platform (docs/automation-platform-spec.md).
# EVERYTHING below is optional in dev: with nothing set, the pipeline runs
# on a local file database and every provider no-ops with a ledger row.
# Outbound channels additionally require their kill switch to be enabled
# in /admin — env vars alone never turn a channel on.
# ═══════════════════════════════════════════════════════════════════════

# ── Database (Turso in production; blank = file:./data/ventwash.db) ──
# On Vercel these are REQUIRED — without them the DB is disabled entirely
# (serverless filesystems are ephemeral; consent records must not be lost).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Cron worker ──────────────────────────────────────────────────────
# Bearer token for GET /api/cron/tick. Unset = cron endpoints open in dev only.
CRON_SECRET=

# ── Site base URL for customer-facing links (emails, SMS) ────────────
# Defaults to the Vercel production URL, or http://localhost:3000 in dev.
SITE_BASE_URL=

# ── Customer link tokens (appointment confirm/reschedule, unsubscribe) ─
# Falls back to SESSION_SECRET when unset.
APPOINTMENT_LINK_SECRET=
# Static key for the founders' read-only calendar feed (/api/admin/calendar.ics?key=...)
ADMIN_ICS_FEED_KEY=

# ── Business identity ────────────────────────────────────────────────
BUSINESS_TIMEZONE=America/New_York
# Physical postal address — REQUIRED in every cold email footer (CAN-SPAM).
BUSINESS_POSTAL_ADDRESS=
# Founder cell for click-to-dial bridge calls and emergency transfers.
FOUNDER_PHONE=
# Founder email for the daily digest + onboarding notifications.
FOUNDER_EMAIL=

# ── Vapi (AI voice, inbound + outbound) ──────────────────────────────
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_INBOUND_ID=
VAPI_ASSISTANT_OUTBOUND_ID=
# Recording is OFF unless this is exactly "1" (all-party consent posture).
RECORDING_ENABLED=
RECORDING_RETENTION_DAYS=90

# ── Twilio (number, SMS, line-type lookup, click-to-dial bridge) ─────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_NUMBER=
# The ONE outbound caller id (Truth in Caller ID — no per-call override exists).
OUTBOUND_CALLER_ID=
# Gate: set to "1" only AFTER A2P 10DLC brand+campaign registration.
SMS_ENABLED=

# ── Resend (transactional + cold email) ──────────────────────────────
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_FROM=
EMAIL_REPLY_TO=
# Cold email sends from a SEPARATE outreach subdomain — never the main domain.
COLD_EMAIL_FROM=
MAX_COLD_EMAILS_PER_DAY=50

# ── Lead discovery ───────────────────────────────────────────────────
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
# Bounding box "south,west,north,east" for the OSM restaurant sweep.
DISCOVERY_BBOX=
CRAWLER_USER_AGENT=

# ── National Do-Not-Call registry (FTC SAN subscription) ─────────────
# Without this + a fresh weekly sync, cold bridge dialing is blocked entirely.
DNC_SAN=
